# App
APP_ENV=development
APP_NAME=migrator-test
APP_VERSION=0.0.1
APP_PORT=8484
APP_DEBUG=false
APP_LOG_LEVEL=info

# PostgreSQL
# All fields are required. DATABASE_URL is used by the migrator CLI.
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/your_db_name?sslmode=disable
